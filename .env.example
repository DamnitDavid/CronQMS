# Environment Configuration Template
# Copy this file to .env and update values for your environment

# Application Settings
APP_NAME=CronQMS
DEBUG=true
ENVIRONMENT=development

# Database Configuration
DATABASE_URL=postgresql://cronqms_user:cronqms_password@localhost:5432/cronqms_db
DATABASE_ECHO=false

# Security & Authentication
# IMPORTANT: Generate strong, unique values before deploying. The app refuses to
# start when ENVIRONMENT is not development/test and these are left at the
# placeholders below. Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET=your-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000","http://127.0.0.1:8000"]

# Password Requirements
PASSWORD_MIN_LENGTH=8

# Public self-service registration (POST /api/auth/register and the /register
# page). Disabled by default: users are provisioned by an admin, and the first
# admin via the /setup wizard. Set to true only if you want open sign-ups.
ALLOW_PUBLIC_REGISTRATION=false

# Session Configuration
SESSION_TIMEOUT_MINUTES=480

# Docker Configuration (if using docker-compose)
# POSTGRES_USER=cronqms_user
# POSTGRES_PASSWORD=cronqms_password
# POSTGRES_DB=cronqms_db
